# Variabel ini diisi di dashboard Vercel (Environment Variables) atau di file .env.local untuk development lokal.

# Email service account Google Cloud (format: xxx@project-id.iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Private key dari service account (copy dari JSON key file, termasuk -----BEGIN/END PRIVATE KEY-----)
GOOGLE_PRIVATE_KEY=

# ID spreadsheet (bagian URL antara /d/ dan /edit)
SPREADSHEET_ID=1Ybtr9Uqxb6LqrjKXxZIwTe2Xv6NOYwx86toRO4B2l6M
